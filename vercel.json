{
  "version": 2,
  "installCommand": "cd backend && npm install",
  "buildCommand": "npm run build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/api", "destination": "/api" }
  ],
  "functions": {
    "api/[[...path]].js": { "maxDuration": 60 }
  }
}
